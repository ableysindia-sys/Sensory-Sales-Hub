# ── Required ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local:      postgres://user:pass@localhost:5432/sensory_sales_hub
# Cloud SQL:  postgres://user:pass@/sensory_sales_hub?host=/cloudsql/PROJECT:asia-south1:sensory-sales-hub-db
DATABASE_URL=

# Admin panel login password
ADMIN_PASSWORD=

# ── Shopify ────────────────────────────────────────────────────────────────────

# Shopify store domain (e.g. 2feec0-4.myshopify.com)
SHOPIFY_STORE_DOMAIN=

# Shopify Storefront API token (public, for cart/checkout)
SHOPIFY_STOREFRONT_TOKEN=

# Shopify app client secret (for webhook HMAC validation)
SHOPIFY_CLIENT_SECRET=

# ── Google AI ──────────────────────────────────────────────────────────────────

# Gemini API key (for the AI chat widget)
GEMINI_API_KEY=

# ── Razorpay ───────────────────────────────────────────────────────────────────

# Razorpay key ID (sample kit deposit payments)
RAZORPAY_KEY_ID=

# Razorpay key secret (HMAC validation)
RAZORPAY_KEY_SECRET=

# ── Runtime ────────────────────────────────────────────────────────────────────

# Server port — Cloud Run sets this to 8080 automatically
PORT=8080

# Set to "production" in Cloud Run
NODE_ENV=production
